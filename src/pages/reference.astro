---
import Layout from '../layouts/Layout.astro';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<Layout title="Reference" description="Quick reference guide for acid-base disorders: normal values, mnemonics, causes, and compensation rules.">
  <div class="reference-page">
    <div class="container">
      <div class="page-header">
        <h1>Acid-Base Quick Reference</h1>
        <p class="page-subtitle">
          Your comprehensive reference card for normal values, mnemonics, causes, and compensation rules.
          Bookmark this page for quick access during clinical rotations.
        </p>
      </div>

      <!-- Normal Values -->
      <section class="ref-section" id="normal-values">
        <h2>📊 Normal ABG Reference Values</h2>
        <div class="ref-table-wrap">
          <table class="ref-table">
            <thead>
              <tr>
                <th>Parameter</th>
                <th>Normal Range</th>
                <th>Unit</th>
                <th>Controlled By</th>
                <th>Acidosis</th>
                <th>Alkalosis</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>pH</strong></td>
                <td class="range">7.35 – 7.45</td>
                <td>—</td>
                <td>Both lungs &amp; kidneys</td>
                <td class="acid">&lt; 7.35</td>
                <td class="alk">&gt; 7.45</td>
              </tr>
              <tr>
                <td><strong>PaCO₂</strong></td>
                <td class="range">35 – 45</td>
                <td>mmHg</td>
                <td>Lungs (respiratory)</td>
                <td class="acid">&gt; 45</td>
                <td class="alk">&lt; 35</td>
              </tr>
              <tr>
                <td><strong>HCO₃⁻</strong></td>
                <td class="range">22 – 26</td>
                <td>mEq/L</td>
                <td>Kidneys (metabolic)</td>
                <td class="acid">&lt; 22</td>
                <td class="alk">&gt; 26</td>
              </tr>
              <tr>
                <td><strong>PaO₂</strong></td>
                <td class="range">80 – 100</td>
                <td>mmHg</td>
                <td>Lungs (oxygenation)</td>
                <td class="acid">&lt; 80 (hypoxemia)</td>
                <td class="alk">—</td>
              </tr>
              <tr>
                <td><strong>SaO₂</strong></td>
                <td class="range">95 – 100%</td>
                <td>%</td>
                <td>Hemoglobin saturation</td>
                <td class="acid">&lt; 95%</td>
                <td class="alk">—</td>
              </tr>
              <tr>
                <td><strong>Base Excess</strong></td>
                <td class="range">-2 to +2</td>
                <td>mEq/L</td>
                <td>Metabolic component</td>
                <td class="acid">&lt; -2</td>
                <td class="alk">&gt; +2</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="pregnancy-note">
          <strong>⚠️ Pregnancy:</strong> Normal values differ — PaCO₂ 27–34 mmHg, HCO₃⁻ 18–22 mEq/L, pH 7.40–7.45 (physiologic respiratory alkalosis)
        </div>
      </section>

      <!-- ROME Mnemonic -->
      <section class="ref-section" id="rome">
        <h2>🔑 The ROME Mnemonic</h2>
        <div class="rome-cards">
          <div class="rome-card rome-resp">
            <div class="rome-letter">R</div>
            <div class="rome-content">
              <h3>Respiratory</h3>
              <div class="rome-letter2">O</div>
              <h3>Opposite</h3>
              <p>pH and PaCO₂ move in <strong>opposite</strong> directions in respiratory disorders.</p>
              <div class="rome-examples">
                <div class="re-item">
                  <span class="arr-down">pH ↓</span> + <span class="arr-up">CO₂ ↑</span> = Resp. Acidosis
                </div>
                <div class="re-item">
                  <span class="arr-up">pH ↑</span> + <span class="arr-down">CO₂ ↓</span> = Resp. Alkalosis
                </div>
              </div>
            </div>
          </div>
          <div class="rome-card rome-met">
            <div class="rome-letter">M</div>
            <div class="rome-content">
              <h3>Metabolic</h3>
              <div class="rome-letter2">E</div>
              <h3>Equal</h3>
              <p>pH and HCO₃⁻ move in the <strong>same (equal)</strong> direction in metabolic disorders.</p>
              <div class="rome-examples">
                <div class="re-item">
                  <span class="arr-down">pH ↓</span> + <span class="arr-down">HCO₃⁻ ↓</span> = Met. Acidosis
                </div>
                <div class="re-item">
                  <span class="arr-up">pH ↑</span> + <span class="arr-up">HCO₃⁻ ↑</span> = Met. Alkalosis
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Master Disorders Table -->
      <section class="ref-section" id="disorders">
        <h2>📋 The Six Acid-Base Disorders at a Glance</h2>
        <div class="ref-table-wrap">
          <table class="ref-table disorders-table">
            <thead>
              <tr>
                <th>Disorder</th>
                <th>pH</th>
                <th>PaCO₂</th>
                <th>HCO₃⁻</th>
                <th>Primary Problem</th>
                <th>Compensation</th>
              </tr>
            </thead>
            <tbody>
              <tr class="row-resp-acid">
                <td><strong>Respiratory Acidosis</strong></td>
                <td class="acid">↓ &lt;7.35</td>
                <td class="acid">↑ &gt;45</td>
                <td class="comp">↑ (compensation)</td>
                <td>Hypoventilation → CO₂ ↑</td>
                <td>Kidneys retain HCO₃⁻</td>
              </tr>
              <tr class="row-resp-alk">
                <td><strong>Respiratory Alkalosis</strong></td>
                <td class="alk">↑ &gt;7.45</td>
                <td class="alk">↓ &lt;35</td>
                <td class="comp">↓ (compensation)</td>
                <td>Hyperventilation → CO₂ ↓</td>
                <td>Kidneys excrete HCO₃⁻</td>
              </tr>
              <tr class="row-met-acid">
                <td><strong>Metabolic Acidosis</strong></td>
                <td class="acid">↓ &lt;7.35</td>
                <td class="comp">↓ (compensation)</td>
                <td class="acid">↓ &lt;22</td>
                <td>HCO₃⁻ loss or acid gain</td>
                <td>Lungs blow off CO₂ (Kussmaul)</td>
              </tr>
              <tr class="row-met-alk">
                <td><strong>Metabolic Alkalosis</strong></td>
                <td class="alk">↑ &gt;7.45</td>
                <td class="comp">↑ (compensation)</td>
                <td class="alk">↑ &gt;26</td>
                <td>H⁺ loss or HCO₃⁻ gain</td>
                <td>Lungs retain CO₂ (hypoventilate)</td>
              </tr>
              <tr>
                <td><strong>Partially Compensated</strong></td>
                <td class="acid-alk">Abnormal</td>
                <td class="comp">Abnormal</td>
                <td class="comp">Abnormal</td>
                <td colspan="2">Both components abnormal; pH still outside normal range</td>
              </tr>
              <tr>
                <td><strong>Fully Compensated</strong></td>
                <td class="normal">Normal</td>
                <td class="comp">Abnormal</td>
                <td class="comp">Abnormal</td>
                <td colspan="2">Both components abnormal; pH within normal range (but near limits)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Common Causes -->
      <section class="ref-section" id="causes">
        <h2>🩺 Common Clinical Causes</h2>
        <div class="causes-grid">
          <div class="causes-card causes-resp-acid">
            <h3>Respiratory Acidosis</h3>
            <p class="causes-subtitle">Anything that ↓ ventilation (CO₂ retention)</p>
            <ul>
              <li>COPD exacerbation</li>
              <li>Asthma (severe)</li>
              <li>Opioid/sedative overdose</li>
              <li>Neuromuscular disease (Guillain-Barré, ALS, myasthenia gravis)</li>
              <li>Chest wall trauma / flail chest</li>
              <li>Sleep apnea / obesity hypoventilation</li>
              <li>Pneumothorax</li>
              <li>Mechanical ventilation (under-ventilation)</li>
            </ul>
          </div>
          <div class="causes-card causes-resp-alk">
            <h3>Respiratory Alkalosis</h3>
            <p class="causes-subtitle">Anything that ↑ ventilation (CO₂ blown off)</p>
            <ul>
              <li>Anxiety / panic attack</li>
              <li>Pain</li>
              <li>Fever / sepsis (early)</li>
              <li>Pulmonary embolism</li>
              <li>High altitude</li>
              <li>Pregnancy (physiologic)</li>
              <li>Mechanical ventilation (over-ventilation)</li>
              <li>CNS stimulation (salicylates, early)</li>
              <li>Liver failure</li>
            </ul>
          </div>
          <div class="causes-card causes-met-acid">
            <h3>Metabolic Acidosis</h3>
            <p class="causes-subtitle">Acid gain or bicarbonate loss</p>
            <div class="causes-sub">
              <strong>↑ Anion Gap (MUDPILES):</strong>
              <ul>
                <li><strong>M</strong>ethanol poisoning</li>
                <li><strong>U</strong>remia (renal failure)</li>
                <li><strong>D</strong>KA (diabetic ketoacidosis)</li>
                <li><strong>P</strong>ropylene glycol</li>
                <li><strong>I</strong>soniazid / Iron toxicity</li>
                <li><strong>L</strong>actic acidosis (sepsis, shock)</li>
                <li><strong>E</strong>thylene glycol</li>
                <li><strong>S</strong>alicylate toxicity</li>
              </ul>
            </div>
            <div class="causes-sub">
              <strong>Normal Anion Gap (HARDUPS):</strong>
              <ul>
                <li>Hyperalimentation / Hyperchloremia</li>
                <li>Acetazolamide</li>
                <li>Renal tubular acidosis (RTA)</li>
                <li>Diarrhea</li>
                <li>Ureteral diversion</li>
                <li>Pancreatic fistula / Posthypocapnia</li>
                <li>Saline excess</li>
              </ul>
            </div>
          </div>
          <div class="causes-card causes-met-alk">
            <h3>Metabolic Alkalosis</h3>
            <p class="causes-subtitle">Acid loss or bicarbonate gain</p>
            <div class="causes-sub">
              <strong>Chloride-Responsive (urine Cl⁻ &lt;20):</strong>
              <ul>
                <li>Vomiting / NG suction</li>
                <li>Diuretics (loop, thiazide)</li>
                <li>Post-hypercapnic alkalosis</li>
              </ul>
            </div>
            <div class="causes-sub">
              <strong>Chloride-Resistant (urine Cl⁻ &gt;20):</strong>
              <ul>
                <li>Hyperaldosteronism (Conn's syndrome)</li>
                <li>Cushing's syndrome / corticosteroids</li>
                <li>Severe hypokalemia</li>
                <li>Excess bicarbonate/antacid ingestion</li>
                <li>Bartter/Gitelman syndrome</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- Compensation Formulas -->
      <section class="ref-section" id="compensation">
        <h2>🔢 Compensation Rules & Formulas</h2>
        <div class="comp-formulas">
          <div class="formula-card">
            <div class="formula-header resp-acid-bg">Respiratory Acidosis Compensation</div>
            <div class="formula-body">
              <div class="formula-row">
                <span class="formula-label">Acute (hrs):</span>
                <code>HCO₃⁻ ↑ 1 mEq/L per 10 mmHg ↑ CO₂</code>
              </div>
              <div class="formula-row">
                <span class="formula-label">Chronic (days):</span>
                <code>HCO₃⁻ ↑ 3.5 mEq/L per 10 mmHg ↑ CO₂</code>
              </div>
              <p class="formula-note">Kidneys retain HCO₃⁻. Takes 3–5 days to fully compensate.</p>
            </div>
          </div>
          <div class="formula-card">
            <div class="formula-header resp-alk-bg">Respiratory Alkalosis Compensation</div>
            <div class="formula-body">
              <div class="formula-row">
                <span class="formula-label">Acute (hrs):</span>
                <code>HCO₃⁻ ↓ 2 mEq/L per 10 mmHg ↓ CO₂</code>
              </div>
              <div class="formula-row">
                <span class="formula-label">Chronic (days):</span>
                <code>HCO₃⁻ ↓ 5 mEq/L per 10 mmHg ↓ CO₂</code>
              </div>
              <p class="formula-note">Kidneys excrete HCO₃⁻. Takes 3–5 days to fully compensate.</p>
            </div>
          </div>
          <div class="formula-card">
            <div class="formula-header met-acid-bg">Metabolic Acidosis Compensation</div>
            <div class="formula-body">
              <div class="formula-row">
                <span class="formula-label">Winter's Formula:</span>
                <code>Expected PaCO₂ = (1.5 × HCO₃⁻) + 8 ± 2</code>
              </div>
              <p class="formula-note">
                Lungs compensate rapidly (minutes to hours) via Kussmaul breathing. 
                If actual CO₂ &gt; expected: concurrent respiratory acidosis. 
                If actual CO₂ &lt; expected: concurrent respiratory alkalosis.
              </p>
            </div>
          </div>
          <div class="formula-card">
            <div class="formula-header met-alk-bg">Metabolic Alkalosis Compensation</div>
            <div class="formula-body">
              <div class="formula-row">
                <span class="formula-label">Expected CO₂:</span>
                <code>PaCO₂ = 0.7 × HCO₃⁻ + 21 ± 2</code>
              </div>
              <p class="formula-note">
                Lungs compensate by hypoventilating (retain CO₂). 
                Limited compensation — PaCO₂ rarely rises above 55 mmHg (hypoxia prevents further hypoventilation).
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Anion Gap -->
      <section class="ref-section" id="anion-gap">
        <h2>⚗️ Anion Gap Calculation</h2>
        <div class="ag-content">
          <div class="formula-card">
            <div class="formula-header" style="background:#5e35b1; color:#fff;">Anion Gap Formula</div>
            <div class="formula-body">
              <div class="formula-row">
                <code class="formula-big">AG = Na⁺ − (Cl⁻ + HCO₃⁻)</code>
              </div>
              <div class="formula-row">
                <span class="formula-label">Normal:</span>
                <code>8–12 mEq/L (without albumin correction)</code>
              </div>
              <div class="formula-row">
                <span class="formula-label">Albumin Correction:</span>
                <code>Corrected AG = AG + 2.5 × (4.0 − albumin g/dL)</code>
              </div>
            </div>
          </div>
          <div class="ag-interpretation">
            <div class="agi-card agi-high">
              <h4>↑ Elevated Anion Gap (&gt;12)</h4>
              <p>Unmeasured anions present (acids). Use <strong>MUDPILES</strong> mnemonic to identify cause.</p>
            </div>
            <div class="agi-card agi-normal">
              <h4>Normal Anion Gap (8–12)</h4>
              <p>Hyperchloremic metabolic acidosis. Use <strong>HARDUPS</strong> to identify cause. HCO₃⁻ replaced by Cl⁻.</p>
            </div>
          </div>
          <div class="delta-gap">
            <h4>Delta-Delta Ratio (mixed disorder screen)</h4>
            <code>(AG − 12) / (24 − HCO₃⁻)</code>
            <div class="dd-interp">
              <span>&lt; 0.4 → Normal AG metabolic acidosis</span>
              <span>0.4–1.0 → Mixed high AG + normal AG acidosis</span>
              <span>1.0–2.0 → Pure high AG metabolic acidosis</span>
              <span>&gt; 2.0 → High AG acidosis + concurrent metabolic alkalosis</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Clinical Mnemonics -->
      <section class="ref-section" id="mnemonics">
        <h2>🧠 Essential Mnemonics</h2>
        <div class="mnemonics-grid">
          <div class="mnemonic-card">
            <h3>MUDPILES — High Anion Gap Metabolic Acidosis</h3>
            <div class="mnemonic-items">
              <div><strong>M</strong> — Methanol / Metformin</div>
              <div><strong>U</strong> — Uremia (renal failure)</div>
              <div><strong>D</strong> — DKA / Alcoholic ketoacidosis</div>
              <div><strong>P</strong> — Propylene glycol / Paraldehyde</div>
              <div><strong>I</strong> — Isoniazid / Iron</div>
              <div><strong>L</strong> — Lactic acidosis</div>
              <div><strong>E</strong> — Ethylene glycol</div>
              <div><strong>S</strong> — Salicylates</div>
            </div>
          </div>
          <div class="mnemonic-card">
            <h3>HARDUPS — Normal Anion Gap Metabolic Acidosis</h3>
            <div class="mnemonic-items">
              <div><strong>H</strong> — Hyperalimentation / Hyperchloremia</div>
              <div><strong>A</strong> — Acetazolamide</div>
              <div><strong>R</strong> — Renal tubular acidosis (RTA)</div>
              <div><strong>D</strong> — Diarrhea</div>
              <div><strong>U</strong> — Ureteral diversion</div>
              <div><strong>P</strong> — Pancreatic fistula</div>
              <div><strong>S</strong> — Saline excess</div>
            </div>
          </div>
          <div class="mnemonic-card">
            <h3>ROME — ABG Interpretation</h3>
            <div class="mnemonic-items">
              <div><strong>R</strong> — Respiratory</div>
              <div><strong>O</strong> — Opposite (pH ↑ CO₂ ↓, or pH ↓ CO₂ ↑)</div>
              <div><strong>M</strong> — Metabolic</div>
              <div><strong>E</strong> — Equal (pH ↑ HCO₃⁻ ↑, or pH ↓ HCO₃⁻ ↓)</div>
            </div>
          </div>
          <div class="mnemonic-card">
            <h3>TICLS — Signs of Respiratory Acidosis</h3>
            <div class="mnemonic-items">
              <div><strong>T</strong> — Tremors / asterixis</div>
              <div><strong>I</strong> — Increased ICP (headache, papilledema)</div>
              <div><strong>C</strong> — Confusion / somnolence</div>
              <div><strong>L</strong> — Lethargy</div>
              <div><strong>S</strong> — Shallow, slow respirations</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Nursing Priorities -->
      <section class="ref-section" id="nursing">
        <h2>💉 Nursing Priority Actions</h2>
        <div class="nursing-grid">
          <div class="nursing-card">
            <h3 class="nc-title resp-acid-color">Respiratory Acidosis</h3>
            <ol>
              <li>Position upright (High Fowler's)</li>
              <li>Administer bronchodilators as ordered</li>
              <li>Encourage coughing and deep breathing</li>
              <li>Prepare for BiPAP or intubation if severe</li>
              <li>Avoid respiratory depressants (opioids, sedatives)</li>
              <li>Monitor O₂ sat, RR, and depth continuously</li>
            </ol>
          </div>
          <div class="nursing-card">
            <h3 class="nc-title resp-alk-color">Respiratory Alkalosis</h3>
            <ol>
              <li>Identify and treat underlying cause</li>
              <li>Coach slow diaphragmatic breathing</li>
              <li>Administer anxiolytics if anxiety-related</li>
              <li>Monitor calcium (alkalosis → hypocalcemia)</li>
              <li>Adjust ventilator settings if intubated</li>
              <li>Reassure and calm the patient</li>
            </ol>
          </div>
          <div class="nursing-card">
            <h3 class="nc-title met-acid-color">Metabolic Acidosis</h3>
            <ol>
              <li>Treat underlying cause (insulin, fluids, dialysis)</li>
              <li>Administer sodium bicarbonate if ordered (severe)</li>
              <li>Monitor potassium closely (K⁺ shifts out of cells)</li>
              <li>IV fluid resuscitation</li>
              <li>Cardiac monitoring for hyperkalemia</li>
              <li>Support respiratory compensation</li>
            </ol>
          </div>
          <div class="nursing-card">
            <h3 class="nc-title met-alk-color">Metabolic Alkalosis</h3>
            <ol>
              <li>Replace potassium (IV or oral KCl)</li>
              <li>Administer isotonic saline (chloride replacement)</li>
              <li>Discontinue causative agents (diuretics, antacids)</li>
              <li>Monitor for hypokalemia and hypocalcemia</li>
              <li>If NG suction: consider H2 blockers</li>
              <li>Monitor cardiac rhythm</li>
            </ol>
          </div>
        </div>
      </section>

      <!-- Quick Interpretation Flowchart -->
      <section class="ref-section" id="flowchart">
        <h2>🗺️ ABG Interpretation Flowchart</h2>
        <div class="flowchart">
          <div class="fc-step fc-start">
            <strong>Start: Obtain ABG Results</strong>
          </div>
          <div class="fc-arrow">↓</div>
          <div class="fc-step fc-decision">
            <strong>Step 1: Is the pH abnormal?</strong>
            <div class="fc-branches">
              <div class="fc-branch">
                <span class="fc-condition">&lt; 7.35</span>
                <span class="fc-result fc-acid">Acidosis</span>
              </div>
              <div class="fc-branch">
                <span class="fc-condition">7.35 – 7.45</span>
                <span class="fc-result fc-normal">Normal (may be compensated)</span>
              </div>
              <div class="fc-branch">
                <span class="fc-condition">&gt; 7.45</span>
                <span class="fc-result fc-alk">Alkalosis</span>
              </div>
            </div>
          </div>
          <div class="fc-arrow">↓</div>
          <div class="fc-step fc-decision">
            <strong>Step 2: Check PaCO₂ (Respiratory)</strong>
            <div class="fc-branches">
              <div class="fc-branch">
                <span class="fc-condition">&gt; 45 mmHg</span>
                <span class="fc-result fc-acid">Resp. Acidosis component</span>
              </div>
              <div class="fc-branch">
                <span class="fc-condition">35–45 mmHg</span>
                <span class="fc-result fc-normal">Normal CO₂</span>
              </div>
              <div class="fc-branch">
                <span class="fc-condition">&lt; 35 mmHg</span>
                <span class="fc-result fc-alk">Resp. Alkalosis component</span>
              </div>
            </div>
          </div>
          <div class="fc-arrow">↓</div>
          <div class="fc-step fc-decision">
            <strong>Step 3: Check HCO₃⁻ (Metabolic)</strong>
            <div class="fc-branches">
              <div class="fc-branch">
                <span class="fc-condition">&lt; 22 mEq/L</span>
                <span class="fc-result fc-acid">Met. Acidosis component</span>
              </div>
              <div class="fc-branch">
                <span class="fc-condition">22–26 mEq/L</span>
                <span class="fc-result fc-normal">Normal HCO₃⁻</span>
              </div>
              <div class="fc-branch">
                <span class="fc-condition">&gt; 26 mEq/L</span>
                <span class="fc-result fc-alk">Met. Alkalosis component</span>
              </div>
            </div>
          </div>
          <div class="fc-arrow">↓</div>
          <div class="fc-step fc-decision">
            <strong>Step 4: Which component matches the pH?</strong>
            <p class="fc-note">That component is the PRIMARY disorder. The other is compensation (if abnormal).</p>
          </div>
          <div class="fc-arrow">↓</div>
          <div class="fc-step fc-decision">
            <strong>Step 5: Determine compensation level</strong>
            <div class="fc-branches">
              <div class="fc-branch">
                <span class="fc-condition">Only 1 abnormal</span>
                <span class="fc-result">Uncompensated</span>
              </div>
              <div class="fc-branch">
                <span class="fc-condition">Both abnormal, pH abnormal</span>
                <span class="fc-result">Partially Compensated</span>
              </div>
              <div class="fc-branch">
                <span class="fc-condition">Both abnormal, pH normal</span>
                <span class="fc-result">Fully Compensated</span>
              </div>
            </div>
          </div>
          <div class="fc-arrow">↓</div>
          <div class="fc-step fc-end">
            <strong>Final Interpretation Complete → Plan Nursing Interventions</strong>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <div class="ref-cta">
        <h3>Practice What You've Learned</h3>
        <p>Put these concepts to work with our interactive tools.</p>
