      target.classList.toggle('visible', isHidden);
      const isQuiz = !!btn.closest('.quiz-item');
      btn.textContent = isHidden
        ? (isQuiz ? 'Hide Explanation' : 'Hide')
        : (isQuiz ? 'Reveal Explanation' : 'Reveal Analysis');
    });
  });

  // Quiz answer highlighting
  document.querySelectorAll<HTMLDivElement>('.quiz-item').forEach(item => {
    const correct = item.getAttribute('data-correct');
    item.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach(radio => {
      radio.addEventListener('change', () => {
        item.querySelectorAll('label').forEach(label => {
          label.classList.remove('correct-answer', 'wrong-answer');
        });
        const selectedLabel = radio.closest('label');
        if (selectedLabel) {
          selectedLabel.classList.add(radio.value === correct ? 'correct-answer' : 'wrong-answer');
        }
      });
    });
  });
</script>

